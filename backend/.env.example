# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Tavily Search
TAVILY_API_KEY=t

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DEFAULT_OPEN_ID=
# 个人空间下文件夹 token，创建的文档会放在此文件夹；不填则创建到应用默认空间
FEISHU_DEFAULT_FOLDER_TOKEN=
# 知识库页面 token（浏览器打开 Wiki 页，URL 里 /wiki/ 后面的那串）；配置后「写文档」将追加到该 Wiki 页
FEISHU_WIKI_NODE_TOKEN=
# 知识库访问域名，用于返回可打开的链接，如 https://ocnxxel690ii.feishu.cn（从浏览器地址栏复制）
FEISHU_WIKI_BASE_URL=

# Embedding（mem0 记忆功能）
# provider 可选: azure | dashscope | zhipu | ollama
EMBEDDING_PROVIDER=dashscope
# 对应 provider 的 API Key（azure 不需要填，复用上面的 AZURE_OPENAI_API_KEY）
EMBEDDING_API_KEY=
# 模型名（接入本地向量网关时可填多模态模型，如 tongyi-embedding-vision-plus）
EMBEDDING_MODEL=tongyi-embedding-vision-plus
# Base URL（使用本地 OpenAI 兼容向量网关）
EMBEDDING_BASE_URL=http://127.0.0.1:8101/v1
# 网关监听端口（start.sh 会读取）
EMBEDDING_GATEWAY_PORT=8101
# 网关上游默认模型（留空则使用 tongyi-embedding-vision-plus）
EMBEDDING_GATEWAY_UPSTREAM_MODEL=tongyi-embedding-vision-plus
# 网关输出向量维度（默认 1536，用于兼容 mem0/openai embedder 预期维度）
EMBEDDING_GATEWAY_TARGET_DIM=1536
# 网关鉴权（可选；配置后客户端需带 Authorization: Bearer <值>）
EMBEDDING_GATEWAY_API_KEY=
# 是否读取旧模型存储（默认关闭，严格一模型一存储）
MEMORY_ENABLE_LEGACY_READ=0
# 是否同时写入旧模型存储（默认关闭）
MEMORY_DUAL_WRITE_LEGACY=0
# 旧模型配置（仅当上面开关打开时才生效）
MEMORY_LEGACY_MODEL=text-embedding-v4
MEMORY_LEGACY_COLLECTION=my_gpt_memories
MEMORY_LEGACY_PATH=data/qdrant

# App
USER_ID=default_user
# 最多允许注册账号数；0 表示不限制（默认 1）
MAX_REGISTERED_USERS=1
MEM0_DIR=
